# Copy to .env. The OpenAI key/model are supplied per-session from the browser;
# OPENAI_HEALTH_KEY is optional and used only for server-side health probes.

# ── server ──
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]

# ── avatar engine ──
# mock        = no GPU, runs anywhere (default; full stack works end-to-end)
# liveavatar  = real WanS2V-14B TPP pipeline (needs the GPU pod + checkpoints)
AVATAR_ENGINE=mock
LIVEAVATAR_REPO=/workspace/LiveAvatar
LIVEAVATAR_CKPT=/workspace/LiveAvatar/ckpt
GPU_COUNT=1
ENABLE_FP8=false
ENABLE_COMPILE=false
PRELOAD_MODEL=0

# ── video / media ──
FRAME_WIDTH=480
FRAME_HEIGHT=480
TARGET_FPS=25
AUDIO_SAMPLE_RATE=24000
AVATAR_AUDIO_RATE=16000

# ── openai defaults (browser may override) ──
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_TTS_MODEL=gpt-4o-mini-tts
DEFAULT_TTS_VOICE=alloy
DEFAULT_STT_MODEL=gpt-4o-mini-transcribe
# OPENAI_HEALTH_KEY=sk-...

# ── webrtc ──
STUN_URLS=["stun:stun.l.google.com:19302"]
# TURN_URL=turn:your.turn.host:3478
# TURN_USER=user
# TURN_PASSWORD=pass
MAX_SESSIONS=8

# ── infra (optional) ──
ENABLE_REDIS=false
ENABLE_POSTGRES=false
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://avatar:avatar@postgres:5432/avatar
